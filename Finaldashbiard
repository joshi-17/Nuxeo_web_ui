<!--
`fid-analytical-dashboard`
@group Nuxeo UI
@element fid-analytical-dashboard

Monthly usage / growth dashboard, designed for very large repositories
(billion-document scale).

Layout:
  - Header card   : title + period selector (+ custom date range)
  - KPI strip     : headline numbers for the selected period
  - Slot 1 (hero) : Growth view with tabs
                    Overall     -> documents line + storage bars (one chart)
                    By Doc Type -> pie of documents per primary type
                    By Format   -> pie of documents per mime-type
                    By Size     -> storage added per month (bar, GB/MB auto)
  - Slot 2        : Migration adoption donut (migrated vs non-migrated)
  - Slots 3-6     : reserved (Coming soon)

Shared CSS lives in fid-dashboard-styles.html and is imported below.

=====================================================================
SCALABILITY NOTES (billion-document design)
=====================================================================
Two different mechanisms are used, each chosen for how it scales:

1. CHARTS (growth, storage, type/format breakdown) use nuxeo-repository-data
   aggregations: grouped-by, with-date-intervals, sum(...). These are
   Elasticsearch aggregations — ES computes them across the whole index and
   returns only the buckets (a handful of rows), never the documents. This
   scales to a billion docs by design.

2. MIGRATION COUNTS use nuxeo-page-provider with NXQL and page-size="1",
   reading ONLY resultsCount. This returns a single filtered count without
   fetching documents, so it also scales. We deliberately do NOT count
   migrated docs with a term aggregation (grouped-by on systemName): at scale
   that would need one bucket per distinct source system and, capped by
   group-limit, would silently undercount. A filtered resultsCount is exact
   and scale-safe.

   We avoid the `where` attribute on nuxeo-repository-data entirely: on this
   build it crashes on ranges / LIKE / IS NOT NULL. NXQL inside a page
   provider supports the complex-field IS NOT NULL predicate correctly and
   fails gracefully instead of taking the page down.
=====================================================================
-->

<!-- Import the shared style module so this file stays focused on markup + logic -->
<link rel="import" href="fid-dashboard-styles.html">

<dom-module id="fid-analytical-dashboard">
  <template>
    <!-- iron-flex gives flex helpers; fid-dashboard-styles holds our CSS -->
    <style include="iron-flex iron-flex-alignment nuxeo-styles fid-dashboard-styles"></style>

    <!-- ============================================================
         CHART DATA — Elasticsearch aggregations (scale-safe).
         Re-run automatically when startDate / endDate change.
         ============================================================ -->

    <!-- Documents created per month (Overall line) -->
    <nuxeo-repository-data
      start-date="[[startDate]]"
      end-date="[[_extendEndDate(endDate)]]"
      with-date-intervals="month"
      date-field="dc:created"
      data="{{docsPerMonth}}"
      index="[[index]]">
    </nuxeo-repository-data>

    <!-- Storage added per month: sum of file sizes in bytes (Overall bars + By Size) -->
    <nuxeo-repository-data
      start-date="[[startDate]]"
      end-date="[[_extendEndDate(endDate)]]"
      with-date-intervals="month"
      date-field="dc:created"
      metrics="sum(file:content.length)"
      data="{{storagePerMonth}}"
      index="[[index]]">
    </nuxeo-repository-data>

    <!-- By Doc Type: documents grouped by primary type (pie) -->
    <nuxeo-repository-data
      start-date="[[startDate]]"
      end-date="[[_extendEndDate(endDate)]]"
      grouped-by="ecm:primaryType"
      group-limit="10"
      data="{{byDocType}}"
      index="[[index]]">
    </nuxeo-repository-data>

    <!-- By Format: documents grouped by mime-type (pie) -->
    <nuxeo-repository-data
      start-date="[[startDate]]"
      end-date="[[_extendEndDate(endDate)]]"
      grouped-by="file:content.mime-type"
      group-limit="10"
      data="{{byFormat}}"
      index="[[index]]">
    </nuxeo-repository-data>

    <!-- Total storage over the period: sum of file sizes in bytes (KPI strip) -->
    <nuxeo-repository-data
      start-date="[[startDate]]"
      end-date="[[_extendEndDate(endDate)]]"
      metrics="sum(file:content.length)"
      data="{{totalStorageBytes}}"
      index="[[index]]">
    </nuxeo-repository-data>

    <!-- ============================================================
         COUNTS — NXQL page providers, resultsCount only (scale-safe).

         page-size="1" + reading resultsCount means ES returns the match
         count without fetching documents. Dates are injected as query
         parameters so the counts respect the selected period.
         ============================================================ -->

    <!-- Total documents in the period.
         The full NXQL is built by _totalQuery with the dates already inlined —
         no ? placeholders, so there is nothing for the page provider to
         substitute (placeholders were reaching the server unsubstituted and
         causing a lexical error). The query is empty until both dates exist,
         and `auto` simply does not fire on an empty query. -->
    <nuxeo-page-provider
      auto
      page-size="1"
      query="[[_totalQuery(startDate, endDate)]]"
      current-page="{{_ignoredTotalPage}}"
      results-count="{{totalCount}}">
    </nuxeo-page-provider>

    <!-- Migrated documents in the period: migrationHistory has at least one entry -->
    <nuxeo-page-provider
      auto
      page-size="1"
      query="[[_migratedQuery(startDate, endDate)]]"
      current-page="{{_ignoredMigratedPage}}"
      results-count="{{migratedCount}}">
    </nuxeo-page-provider>

    <!-- ============================================================
         PER-MONTH MIGRATED COUNTS (exact, period-scoped, scale-safe).

         The period is at most 12 months, so we run one count query per
         month. Each is page-size="1" reading results-count, so it returns a
         single number and fetches no documents — cheap at any repository
         size. _months is rebuilt whenever the date range changes; each
         repeated provider writes its month's migrated count back through
         the count handlers, which assemble the monthlyMigrated array the chart
         reads. All-docs-per-month already comes from the dc:created
         histogram (docsPerMonth), so non-migrated = all - migrated.
         ============================================================ -->
    <template is="dom-repeat" items="[[_months]]" as="m">
      <!-- Migrated docs in this month -->
      <nuxeo-page-provider
        auto
        page-size="1"
        query="[[_monthMigratedQuery(m)]]"
        current-page="{{_ignoredMonthPage}}"
        results-count="{{_noopA}}"
        on-results-count-changed="_onMigratedCount">
      </nuxeo-page-provider>
      <!-- Total docs in this month (so non-migrated = total - migrated) -->
      <nuxeo-page-provider
        auto
        page-size="1"
        query="[[_monthTotalQuery(m)]]"
        current-page="{{_ignoredMonthPage2}}"
        results-count="{{_noopB}}"
        on-results-count-changed="_onTotalCount">
      </nuxeo-page-provider>
    </template>



    <!-- ============================================================
         PAGE
         ============================================================ -->
    <div class="page">
      <div class="content">
        <nuxeo-page>

          <!-- Nuxeo admin top bar -->
          <div slot="header">
            <span class="flex">Analytical Dashboard</span>
          </div>

          <div class="dashboard-container">

            <!-- ---------- HEADER CARD: title + period selector ---------- -->
            <nuxeo-card class="dates">
              <div class="header-slot">

                <div class="header-left">
                  <h1>Analytical Dashboard</h1>
                  <p>Monthly usage tracking, growth metrics and adoption overview</p>
                </div>

                <div class="header-divider"></div>

                <div class="header-controls">
                  <nuxeo-select
                    label="Period"
                    selected="{{selectedPeriod}}"
                    options='["1month","2months","3months","4months","6months","8months","10months","1year","custom"]'
                    on-selected-changed="_onPeriodChanged">
                  </nuxeo-select>

                  <!-- Custom date pickers appear only for the custom option -->
                  <template is="dom-if" if="[[_isCustom(selectedPeriod)]]">
                    <div class="custom-dates">
                      <div class="date-field">
                        <label>Start Date</label>
                        <input type="date" value="{{customStart::change}}" on-change="_onCustomDateChanged" />
                      </div>
                      <div class="date-field">
                        <label>End Date</label>
                        <input type="date" value="{{customEnd::change}}" on-change="_onCustomDateChanged" />
                      </div>
                    </div>
                  </template>
                </div>

              </div>
            </nuxeo-card>

            <!-- ---------- KPI STRIP: headline numbers ---------- -->
            <div class="flex-layout tight">
              <nuxeo-card class="full-width">
                <div class="kpi-strip">

                  <div class="kpi-cell">
                    <span class="kpi-value">[[_formatCount(totalCount)]]</span>
                    <span class="kpi-label">New documents in period</span>
                  </div>

                  <div class="kpi-cell">
                    <span class="kpi-value">[[_formatStorage(totalStorageBytes)]]</span>
                    <span class="kpi-label">Storage added in period</span>
                  </div>

                  <div class="kpi-cell">
                    <span class="kpi-value">[[migratedCount]]</span>
                    <span class="kpi-label">From migrated use cases</span>
                  </div>

                  <div class="kpi-cell">
                    <span class="kpi-value">[[_nonMigrated(totalCount, migratedCount)]]</span>
                    <span class="kpi-label">From non-migrated use cases</span>
                  </div>

                </div>
              </nuxeo-card>
            </div>

            <!-- ---------- CARD GRID ---------- -->
            <div class="flex-layout">

              <!-- ===== SLOT 1 (hero): Growth view with tabs ===== -->
              <nuxeo-card class="full-width" heading="Growth Overview">

                <!-- Tab toolbar: clicking sets activeView -->
                <div class="view-tabs">
                  <span class$="[[_tabClass(activeView, 'overall')]]" on-tap="_selectOverall">Overall</span>
                  <span class$="[[_tabClass(activeView, 'docType')]]" on-tap="_selectDocType">By Doc Type</span>
                  <span class$="[[_tabClass(activeView, 'format')]]"  on-tap="_selectFormat">By Format</span>
                  <span class$="[[_tabClass(activeView, 'size')]]"    on-tap="_selectSize">By Size</span>
                </div>

                <!-- OVERALL: storage bars + documents line on one chart -->
                <template is="dom-if" if="[[_isView(activeView, 'overall')]]">
                  <div class="chart-sub-title">Documents and storage added per month</div>
                  <div class="chart-box">
                    <chart-bar
                      labels="[[_monthLabels(storagePerMonth)]]"
                      values="[[_overallValues(storagePerMonth, docsPerMonth, totalCount)]]"
                      series="[[_overallSeries(storagePerMonth)]]"
                      options="[[_overallOptions(storagePerMonth)]]">
                    </chart-bar>
                  </div>
                </template>

                <!-- BY DOC TYPE: pie of documents per primary type -->
                <template is="dom-if" if="[[_isView(activeView, 'docType')]]">
                  <div class="chart-sub-title">Documents by type</div>
                  <template is="dom-if" if="[[!_isEmpty(byDocType)]]">
                    <div class="chart-box">
                      <chart-pie
                        labels="[[_labels(byDocType)]]"
                        values="[[_values(byDocType)]]"
                        options='{"responsive":true,"maintainAspectRatio":false,"legend":{"display":true,"position":"right","labels":{"boxWidth":12,"fontSize":11,"padding":10}},"animation":false,"tooltips":{"enabled":true}}'>
                      </chart-pie>
                    </div>
                  </template>
                  <template is="dom-if" if="[[_isEmpty(byDocType)]]">
                    <div class="chart-empty">No documents found in this period</div>
                  </template>
                </template>

                <!-- BY FORMAT: pie of documents per mime-type -->
                <template is="dom-if" if="[[_isView(activeView, 'format')]]">
                  <div class="chart-sub-title">Documents by format</div>
                  <template is="dom-if" if="[[!_isEmpty(byFormat)]]">
                    <div class="chart-box">
                      <chart-pie
                        labels="[[_typeLabels(byFormat)]]"
                        values="[[_values(byFormat)]]"
                        options='{"responsive":true,"maintainAspectRatio":false,"legend":{"display":true,"position":"right","labels":{"boxWidth":12,"fontSize":11,"padding":10}},"animation":false,"tooltips":{"enabled":true}}'>
                      </chart-pie>
                    </div>
                  </template>
                  <template is="dom-if" if="[[_isEmpty(byFormat)]]">
                    <div class="chart-empty">No files found in this period</div>
                  </template>
                </template>

                <!-- BY SIZE: storage added per month (bar, unit auto-scaled) -->
                <template is="dom-if" if="[[_isView(activeView, 'size')]]">
                  <div class="chart-sub-title">Storage added per month</div>
                  <div class="chart-box">
                    <chart-bar
                      labels="[[_monthLabels(storagePerMonth)]]"
                      values="[[_storageValues(storagePerMonth)]]"
                      series="[[_storageSeries(storagePerMonth)]]"
                      options='{"responsive":true,"maintainAspectRatio":false,"legend":{"display":true,"position":"top","labels":{"boxWidth":10,"fontSize":11,"padding":12}},"animation":false,"scales":{"xAxes":[{"gridLines":{"display":false,"drawBorder":false},"ticks":{"autoSkip":false,"maxRotation":30,"fontSize":11,"fontColor":"#9e9e9e"}}],"yAxes":[{"gridLines":{"color":"rgba(0,0,0,0.04)","drawBorder":false},"ticks":{"beginAtZero":true,"fontSize":11,"fontColor":"#9e9e9e"}}]},"tooltips":{"mode":"index","intersect":false}}'>
                    </chart-bar>
                  </div>
                </template>

              </nuxeo-card>

              <!-- ===== SLOT 2: Migration adoption donut ===== -->
              <nuxeo-card heading="Migration Adoption">
                <div class="donut-wrap">
                  <chart-pie
                    labels="[[_migrationLabels()]]"
                    values="[[_migrationValues(totalCount, migratedCount)]]"
                    colors='["#2e7d32","#d32f2f"]'
                    options='{"responsive":true,"maintainAspectRatio":false,"cutoutPercentage":68,"legend":{"display":true,"position":"bottom","labels":{"boxWidth":12,"fontSize":11,"padding":12}},"animation":false,"tooltips":{"enabled":true}}'>
                  </chart-pie>
                  <div class="donut-center">
                    <span class="pct">[[_migratedPct(totalCount, migratedCount)]]%</span>
                    <span class="pct-label">MIGRATED</span>
                  </div>
                </div>
                <div class="migration-summary">
                  <div class="stat">
                    <span class="num">[[migratedCount]]</span>
                    <span class="lbl">Migrated</span>
                  </div>
                  <div class="stat">
                    <span class="num">[[_nonMigrated(totalCount, migratedCount)]]</span>
                    <span class="lbl">Non-Migrated</span>
                  </div>
                  <div class="stat">
                    <span class="num">[[totalCount]]</span>
                    <span class="lbl">Total</span>
                  </div>
                </div>
              </nuxeo-card>

              <!-- ===== SLOT 3 ===== -->
              <!-- ===== Monthly Migrated vs Non-Migrated (full-width) ===== -->
              <nuxeo-card class="full-width" heading="Monthly Migration">
                <div class="chart-sub-title">Migrated vs non-migrated documents per month</div>
                <template is="dom-if" if="[[!_monthlyEmpty(monthlyMigrated)]]">
                  <div class="chart-box">
                    <chart-bar
                      labels="[[_monthlyLabels(monthlyMigrated)]]"
                      values="[[_monthlyValues(monthlyMigrated)]]"
                      series="[[_monthlySeries()]]"
                      colors="[[_monthlyColors()]]"
                      options='{"responsive":true,"maintainAspectRatio":false,"legend":{"display":true,"position":"top","labels":{"boxWidth":10,"fontSize":11,"padding":12}},"animation":false,"scales":{"xAxes":[{"gridLines":{"display":false,"drawBorder":false},"ticks":{"autoSkip":false,"maxRotation":30,"fontSize":11,"fontColor":"#9e9e9e"}}],"yAxes":[{"gridLines":{"color":"rgba(0,0,0,0.04)","drawBorder":false},"ticks":{"beginAtZero":true,"fontSize":11,"fontColor":"#9e9e9e"}}]},"tooltips":{"mode":"index","intersect":false}}'>
                    </chart-bar>
                  </div>
                </template>
                <template is="dom-if" if="[[_monthlyEmpty(monthlyMigrated)]]">
                  <div class="chart-empty">No documents found in this period</div>
                </template>
              </nuxeo-card>

              <!-- ===== SLOT 4 ===== -->
              <nuxeo-card heading="Slot 4">
                <div class="slot-placeholder">
                  <iron-icon icon="icons:insert-chart"></iron-icon>
                  <span class="placeholder-label">Coming soon</span>
                </div>
              </nuxeo-card>

              <!-- ===== SLOT 5 ===== -->
              <nuxeo-card heading="Slot 5">
                <div class="slot-placeholder">
                  <iron-icon icon="icons:insert-chart"></iron-icon>
                  <span class="placeholder-label">Coming soon</span>
                </div>
              </nuxeo-card>

              <!-- ===== SLOT 6 ===== -->
              <nuxeo-card heading="Slot 6">
                <div class="slot-placeholder">
                  <iron-icon icon="icons:insert-chart"></iron-icon>
                  <span class="placeholder-label">Coming soon</span>
                </div>
              </nuxeo-card>

            </div>

          </div>

        </nuxeo-page>
      </div>
    </div>

  </template>

  <script>
    Polymer({
      is: 'fid-analytical-dashboard',
      behaviors: [Nuxeo.LayoutBehavior],

      observers: [
        '_buildMonths(startDate, endDate)'
      ],

      properties: {

        // ---- Period selection ----
        selectedPeriod: { type: String, value: '6months', observer: '_onPeriodChanged' },
        startDate:      { type: String, notify: true },
        endDate:        { type: String, notify: true },
        customStart:    { type: String },
        customEnd:      { type: String },

        // ---- Which hero tab is active: overall | docType | f
