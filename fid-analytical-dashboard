<!--
`fid-analytical-dashboard`
@group Nuxeo UI
@element fid-analytical-dashboard
-->
<dom-module id="fid-analytical-dashboard">
  <template>
    <style include="nuxeo-styles">

      /* ══════════════════════════════════
         BASE
         ══════════════════════════════════ */
      .page, .content {
        @apply --layout-vertical;
      }

      .dashboard-container {
        padding: 24px;
        background: var(--nuxeo-page-background, #f5f5f5);
        min-height: 100vh;
      }

      /* ══════════════════════════════════
         HEADER CARD
         ══════════════════════════════════ */
      .header-card-inner {
        display: flex;
        flex-direction: row;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 16px;
        padding: 4px 0;
      }

      .header-left h1 {
        font-size: 22px;
        font-weight: 400;
        color: var(--nuxeo-text-default, #333);
        margin: 0 0 4px 0;
        letter-spacing: -0.3px;
      }

      .header-left h3 {
        font-size: 13px;
        color: var(--nuxeo-text-light, #999);
        margin: 0;
        font-weight: 400;
      }

      .header-controls {
        display: flex;
        flex-direction: row;
        align-items: flex-end;
        gap: 16px;
        flex-wrap: wrap;
      }

      .header-controls nuxeo-select {
        min-width: 150px;
      }

      .custom-dates {
        display: flex;
        flex-direction: row;
        align-items: flex-end;
        gap: 12px;
      }

      .date-field {
        display: flex;
        flex-direction: column;
        gap: 4px;
      }

      .date-field label {
        font-size: 11px;
        color: var(--nuxeo-text-light, #999);
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 0.5px;
      }

      .date-field input[type="date"] {
        padding: 0 10px;
        border: 1px solid var(--nuxeo-border, #e0e0e0);
        border-radius: 2px;
        font-size: 13px;
        color: var(--nuxeo-text-default, #333);
        background: white;
        height: 32px;
        box-sizing: border-box;
        font-family: var(--nuxeo-app-font, 'Roboto', sans-serif);
        transition: border-color 0.15s ease;
      }

      .date-field input[type="date"]:focus {
        outline: none;
        border-color: var(--nuxeo-primary-color, #0066ff);
        box-shadow: 0 0 0 2px rgba(0, 102, 255, 0.1);
      }

      /* ══════════════════════════════════
         SLOT GRID — 3 per row
         ══════════════════════════════════ */
      .slot-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 20px;
        margin-top: 20px;
      }

      /* Each slot is a nuxeo-card wrapper */
      .slot-grid nuxeo-card {
        margin: 0 !important;
        min-height: 320px;
        display: flex;
        flex-direction: column;
      }

      /* Slot 1 spans full row — the main chart */
      .slot-grid nuxeo-card.slot-main {
        grid-column: 1 / -1;
        min-height: 420px;
      }

      /* ══════════════════════════════════
         CHART WRAPPER
         ══════════════════════════════════ */
      .chart-wrapper {
        position: relative;
        width: 100%;
        height: 340px;
        margin-top: 8px;
      }

      .chart-wrapper-small {
        position: relative;
        width: 100%;
        height: 220px;
        margin-top: 8px;
      }

      chart-line,
      chart-pie,
      chart-bar {
        display: block;
        width: 100% !important;
        height: 100% !important;
        font-size: 0.8rem;
      }

      /* ══════════════════════════════════
         EMPTY SLOT PLACEHOLDER
         ══════════════════════════════════ */
      .slot-placeholder {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        height: 100%;
        min-height: 240px;
        color: var(--nuxeo-text-light, #bbb);
        gap: 12px;
      }

      .slot-placeholder iron-icon {
        --iron-icon-width: 48px;
        --iron-icon-height: 48px;
        color: var(--nuxeo-border, #ddd);
      }

      .slot-placeholder span {
        font-size: 13px;
        color: var(--nuxeo-text-light, #bbb);
      }

      /* ══════════════════════════════════
         RESPONSIVE
         ══════════════════════════════════ */
      @media (max-width: 1024px) {
        .slot-grid {
          grid-template-columns: repeat(2, 1fr);
        }
        .slot-grid nuxeo-card.slot-main {
          grid-column: 1 / -1;
        }
      }

      @media (max-width: 768px) {
        .slot-grid {
          grid-template-columns: 1fr;
        }
        .slot-grid nuxeo-card.slot-main {
          grid-column: 1;
        }
        .header-card-inner {
          flex-direction: column;
          align-items: flex-start;
        }
        .header-controls {
          flex-direction: column;
          align-items: flex-start;
          width: 100%;
        }
        .custom-dates {
          flex-direction: column;
          width: 100%;
        }
      }

    </style>

    <!-- ══════════════════════════════════════════
         ES DATA ELEMENT — documents created/month
         ══════════════════════════════════════════ -->
    <nuxeo-repository-data
      start-date="[[startDate]]"
      end-date="[[_extendEndDate(endDate)]]"
      with-date-intervals="month"
      date-field="dc:created"
      data="{{docsCreatedPerMonth}}"
      index="[[index]]">
    </nuxeo-repository-data>

    <!-- ══════════════════════════════════
         PAGE
         ══════════════════════════════════ -->
    <div class="page">
      <div class="content">
        <nuxeo-page>

          <!-- Nuxeo admin title bar -->
          <div slot="header">
            <span class="flex">Analytical Dashboard</span>
          </div>

          <div class="dashboard-container">

            <!-- ── Header card: full width ── -->
            <nuxeo-card>
              <div class="header-card-inner">
                <div class="header-left">
                  <h1>Analytical Dashboard</h1>
                  <h3>Monthly usage tracking, growth metrics and adoption overview</h3>
                </div>
                <div class="header-controls">
                  <nuxeo-select
                    label="Period"
                    selected="{{selectedPeriod}}"
                    options='["1month","2months","3months","4months","6months","8months","10months","1year","custom"]'
                    on-selected-changed="_onPeriodChanged">
                  </nuxeo-select>
                  <template is="dom-if" if="[[_isCustom(selectedPeriod)]]">
                    <div class="custom-dates">
                      <div class="date-field">
                        <label>Start Date</label>
                        <input type="date" value="{{customStart::change}}" />
                      </div>
                      <div class="date-field">
                        <label>End Date</label>
                        <input type="date" value="{{customEnd::change}}" />
                      </div>
                    </div>
                  </template>
                </div>
              </div>
            </nuxeo-card>

            <!-- ── 6 slot grid: 3 per row ── -->
            <div class="slot-grid">

              <!-- SLOT 1: Document Growth chart — spans full row -->
              <nuxeo-card class="slot-main" heading="Document Growth">
                <div class="chart-wrapper">
                  <chart-line
                    labels="[[_labels(docsCreatedPerMonth)]]"
                    values="[[_values(docsCreatedPerMonth)]]"
                    series='["Documents Created"]'
                    options='{"responsive":true,"maintainAspectRatio":false,"legend":{"display":true,"position":"top","labels":{"boxWidth":12,"fontSize":12,"fontColor":"#666"}},"animation":false,"elements":{"line":{"tension":0.4,"borderWidth":2,"borderColor":"#1a73e8","backgroundColor":"rgba(26,115,232,0.08)","fill":true},"point":{"radius":4,"hoverRadius":6,"backgroundColor":"#1a73e8","borderColor":"#fff","borderWidth":2}},"scales":{"xAxes":[{"gridLines":{"display":true,"color":"rgba(0,0,0,0.04)","zeroLineColor":"rgba(0,0,0,0.1)"},"ticks":{"autoSkip":false,"maxRotation":35,"minRotation":0,"fontSize":11,"fontColor":"#888","padding":8}}],"yAxes":[{"gridLines":{"display":true,"color":"rgba(0,0,0,0.04)","zeroLineColor":"rgba(0,0,0,0.1)"},"ticks":{"beginAtZero":true,"stepSize":1,"fontSize":11,"fontColor":"#888","padding":8}}]}}'>
                  </chart-line>
                </div>
              </nuxeo-card>

              <!-- SLOT 2: Placeholder -->
              <nuxeo-card heading="Slot 2">
                <div class="slot-placeholder">
                  <iron-icon icon="icons:insert-chart"></iron-icon>
                  <span>Coming soon</span>
                </div>
              </nuxeo-card>

              <!-- SLOT 3: Placeholder -->
              <nuxeo-card heading="Slot 3">
                <div class="slot-placeholder">
                  <iron-icon icon="icons:insert-chart"></iron-icon>
                  <span>Coming soon</span>
                </div>
              </nuxeo-card>

              <!-- SLOT 4: Placeholder -->
              <nuxeo-card heading="Slot 4">
                <div class="slot-placeholder">
                  <iron-icon icon="icons:insert-chart"></iron-icon>
                  <span>Coming soon</span>
                </div>
              </nuxeo-card>

              <!-- SLOT 5: Placeholder -->
              <nuxeo-card heading="Slot 5">
                <div class="slot-placeholder">
                  <iron-icon icon="icons:insert-chart"></iron-icon>
                  <span>Coming soon</span>
                </div>
              </nuxeo-card>

              <!-- SLOT 6: Placeholder -->
              <nuxeo-card heading="Slot 6">
                <div class="slot-placeholder">
                  <iron-icon icon="icons:insert-chart"></iron-icon>
                  <span>Coming soon</span>
                </div>
              </nuxeo-card>

            </div>
            <!-- end .slot-grid -->

          </div>
          <!-- end .dashboard-container -->

        </nuxeo-page>
      </div>
    </div>

  </template>

  <script>
    Polymer({
      is: 'fid-analytical-dashboard',
      behaviors: [Nuxeo.LayoutBehavior],

      properties: {

        selectedPeriod: {
          type: String,
          value: '6months',
          observer: '_onPeriodChanged'
        },

        startDate: {
          type: String,
          notify: true
        },

        endDate: {
          type: String,
          notify: true
        },

        customStart: {
          type: String
        },

        customEnd: {
          type: String
        },

        index: {
          type: String,
          value: '_all'
        },

        docsCreatedPerMonth: {
          type: Array,
          value: function() { return []; }
        }

      },

      ready: function() {
        this._computeDates(this.selectedPeriod);
      },

      // ── Period helpers ──

      _isCustom: function(period) {
        return period === 'custom';
      },

      _onPeriodChanged: function(newVal) {
        if (!newVal || newVal === 'custom') return;
        this._computeDates(newVal);
      },

      _computeDates: function(period) {
        var monthMap = {
          '1month':   1,
          '2months':  2,
          '3months':  3,
          '4months':  4,
          '6months':  6,
          '8months':  8,
          '10months': 10,
          '1year':    12
        };
        var months = monthMap[period];
        if (!months) return;

        var end   = new Date();
        var start = new Date();
        start.setMonth(start.getMonth() - months);

        this.startDate = this._toISODate(start);
        this.endDate   = this._toISODate(end);
      },

      _toISODate: function(date) {
        return date.toISOString().split('T')[0];
      },

      // ── Chart helper functions ──

      // Extracts X-axis labels from ES response
      // ES returns: [{key:"2026-01-01", value:5}, ...]
      // _labels returns: ["2026-01-01", "2026-02-01", ...]
      _labels: function(data) {
        if (!data || !data.length) return [];
        return data.map(function(entry) {
          return entry.key;
        });
      },

      // Extracts Y-axis values from ES response
      // chart-line expects nested array: [[v1, v2, v3]]
      // outer array = series, inner = data points
      _values: function(data) {
        if (!data || !data.length) return [[]];
        return [data.map(function(entry) {
          return entry.value;
        })];
      },

      // Extends endDate to 23:59:59.999 of that day
      // so ES range is fully inclusive of today's documents
      _extendEndDate: function(date) {
        if (!date) return date;
        var d = new Date(date);
        d.setDate(d.getDate() + 1);
        d.setMilliseconds(d.getMilliseconds() - 1);
        return d.toISOString();
      },

      // Custom date range handler — Phase 2
      _onCustomDateChanged: function() {
        if (this.customStart && this.customEnd) {
          this.startDate = this.customStart;
          this.endDate   = this.customEnd;
        }
      }

    });
  </script>

</dom-module>
